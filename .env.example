# SenKey full-repo environment template
# Copy this file to `.env` before deploying the backend or building a custom
# extension. The published extension does not require custom OAuth values.

# ---- Cloud Run backend ----

# Google Cloud project used by ./deploy.sh.
PROJECT_ID=your-gcp-project-id

# Cloud Run region.
REGION=us-west1

# Shared key required by the extension when it calls your backend. Leave blank to
# let ./deploy.sh generate a strong key and write it back to `.env`.
API_KEY=

# Published SenKey Chrome Web Store extension ID. Keep this value when deploying
# a backend for the published extension. Use your installed extension ID only for
# custom builds.
CHROME_EXTENSION_ID=gcmgfpkabdjhniklindbjieohnfngchg

# ---- Custom extension OAuth ----
# Leave these blank when using the published extension unchanged.

# Chrome Extension OAuth client for production custom builds and Web Store
# upload builds.
GOOGLE_OAUTH_CLIENT_ID=

# Chrome Extension OAuth client for unpacked dev builds. Its Chrome App / Item
# ID must match the dev extension ID printed by ./build.sh.
DEV_GOOGLE_OAUTH_CLIENT_ID=

# Optional Web Application OAuth client used by Brave's fallback sign-in flow.
# Authorized redirect URI:
# https://<extension-id>.chromiumapp.org/oauth2
WEB_GOOGLE_OAUTH_CLIENT_ID=

# ---- Dev build identity ----

# Optional base64 public key for a stable unpacked extension ID. If blank,
# ./build.sh creates and reuses extension.dev.pem. Production builds never
# include a manifest key.
EXTENSION_KEY=
