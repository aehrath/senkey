# Your Google Cloud project ID used for Cloud Run and Storage.
PROJECT_ID=your-gcp-project-id

# Cloud Run region. Keep us-west1 unless you want a different region.
REGION=us-west1

# Shared secret used by the extension when calling your backend.
# Leave blank to have ./deploy.sh generate and save a strong key automatically.
API_KEY=

# Chrome Web Store extension ID for the published SenKey extension.
CHROME_EXTENSION_ID=gcmgfpkabdjhniklindbjieohnfngchg

# Only needed when building your own extension. Users of the published
# extension should not change OAuth settings.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional. If set, non-prod builds use this OAuth client instead of
# GOOGLE_OAUTH_CLIENT_ID. Create it as a Chrome Extension OAuth client whose
# Chrome App / Item ID matches the dev extension ID printed by ./build.sh.
DEV_GOOGLE_OAUTH_CLIENT_ID=

# Optional. Dev builds use EXTENSION_KEY if set. If it is blank, ./build.sh
# creates extension.dev.pem locally and reuses it so the unpacked extension ID
# stays stable. Production builds never include a manifest key.
EXTENSION_KEY=
