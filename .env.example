# SenKey full-repo environment
# Copy to `.env` when deploying the backend or building a custom extension.

# ---- Cloud Run backend ----

# Google Cloud project used by ./deploy.sh.
PROJECT_ID=your-gcp-project-id

# Cloud Run region.
REGION=us-west1

# Shared key required by the extension when it calls your backend.
# Leave blank to let ./deploy.sh generate and save a strong key.
API_KEY=

# Published SenKey Chrome Web Store extension ID. Keep this value when using
# the published extension. Custom builds may use their own installed ID.
CHROME_EXTENSION_ID=gcmgfpkabdjhniklindbjieohnfngchg

# ---- Custom extension OAuth ----
# Leave these unchanged when using the published extension.

# Chrome Extension OAuth client for production custom builds.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Chrome Extension OAuth client for unpacked dev builds. Its Chrome App / Item
# ID must match the dev extension ID printed by ./build.sh.
DEV_GOOGLE_OAUTH_CLIENT_ID=

# Web Application OAuth client used by Brave's fallback sign-in flow.
# Authorized redirect URI:
# https://<extension-id>.chromiumapp.org/oauth2
WEB_GOOGLE_OAUTH_CLIENT_ID=

# ---- Dev build identity ----

# Optional base64 public key for a stable unpacked extension ID. If blank,
# ./build.sh creates and reuses extension.dev.pem. Production builds do not
# include a manifest key.
EXTENSION_KEY=
