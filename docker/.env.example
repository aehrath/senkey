# SenKey Cloud Run backend environment template
# Copy this file to `.env` when using the backend-only deployment bundle.

# Google Cloud project used by docker/deploy.sh.
PROJECT_ID=your-gcp-project-id

# Cloud Run region.
REGION=us-west1

# Shared key required by the extension when it calls your backend. Leave blank to
# let deploy.sh generate a strong key and write it back to `.env`.
API_KEY=

# Published SenKey Chrome Web Store extension ID.
# Keep this value when deploying a backend for the published extension. Use your
# installed extension ID only for custom builds.
CHROME_EXTENSION_ID=gcmgfpkabdjhniklindbjieohnfngchg
