# Your Google Cloud project ID used for Cloud Run and Storage.
PROJECT_ID=your-gcp-project-id

# Cloud Run region. Keep us-west1 unless you want a different region.
REGION=us-west1

# Shared secret used by the extension when calling your backend.
# Leave blank to have ./deploy.sh generate and save a strong key automatically.
API_KEY=

# Chrome Web Store extension ID for the published SenKey extension.
CHROME_EXTENSION_ID=gcmgfpkabdjhniklindbjieohnfngchg
