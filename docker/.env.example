# SenKey Cloud Run backend environment
# Copy to `.env` when using the backend-only deployment bundle.

# Google Cloud project used by docker/deploy.sh.
PROJECT_ID=your-gcp-project-id

# Cloud Run region.
REGION=us-west1

# Shared key required by the extension when it calls your backend.
# Leave blank to let deploy.sh generate and save a strong key.
API_KEY=

# Published SenKey Chrome Web Store extension ID.
# Keep this value unless you are deploying for a custom extension build.
CHROME_EXTENSION_ID=gcmgfpkabdjhniklindbjieohnfngchg
