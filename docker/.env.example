# SenKey Cloud Run backend environment template
# Copy this file to `.env` when using the backend-only deployment bundle.

# Google Cloud project used by docker/deploy.sh.
PROJECT_ID=your-gcp-project-id

# Cloud Run region.
REGION=us-west1

# Shared key required by the extension when it calls your backend. Leave blank to
# let deploy.sh generate a strong key and write it back to `.env`.
API_KEY=

# Published SenKey Chrome Web Store extension ID. The backend does not require
# this at runtime; deploy.sh prints it as an OAuth setup reference. Keep the
# default for the published extension.
CHROME_EXTENSION_ID=gcmgfpkabdjhniklindbjieohnfngchg

# Optional backend hardening override. Usually leave blank: deploy.sh uses the
# published OAuth IDs for the published extension. For custom extension builds,
# set this to the comma-separated OAuth client IDs your extension can use.
GOOGLE_OAUTH_CLIENT_IDS=
