{
  "manifest_version": 3,
  "name": "SenKey",
  "version": "1.3.3",
  "description": "Store and autofill passwords from your own backend with Google sign-in and client-side encryption.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "identity",
    "bookmarks"
  ],
  "oauth2": {
    "client_id": "456135155814-qgt4cb89sv1vsgtl4jtljev698tbhdjp.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "key": ""
}
